{
  "name": "shadcn-virtualized-tree",
  "version": "0.1.0",
  "description": "Headless and styled virtualized tree components for React",
  "license": "MIT",
  "author": "Muhammad Usama Bin Akhtar Khan",
  "homepage": "https://usamakhangt4.github.io/shadcn-virtualized-tree/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usamakhangt4/shadcn-virtualized-tree.git"
  },
  "bugs": {
    "url": "https://github.com/usamakhangt4/shadcn-virtualized-tree/issues"
  },
  "keywords": [
    "react",
    "tree",
    "tree-view",
    "virtualized",
    "shadcn",
    "typescript",
    "drag-and-drop",
    "accessibility"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build",
    "dev": "tsup --watch",
    "playground": "vite --config playground/vite.config.ts",
    "playground:build": "vite build --config playground/vite.config.ts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build && npm run playground:build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
